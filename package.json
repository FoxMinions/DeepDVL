{
  "name": "deepdvl",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "description": "深度数界实验室 DeepDVL —— 一个从 0 到 1 教你制作数据可视化大屏的公开学习项目",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && stylelint \"src/**/*.{css,vue}\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "echarts": "^5.6.0",
    "msw": "^2.14.6",
    "pinia": "^2.3.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
